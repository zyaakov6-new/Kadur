{
  "expo": {
    "name": "קדור",
    "slug": "kadur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kadur",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F23"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kadur.app",
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "אנחנו צריכים את המיקום שלך כדי להציג משחקים בקרבתך",
        "NSLocationAlwaysUsageDescription": "אנחנו צריכים את המיקום שלך כדי להציג משחקים בקרבתך",
        "NSCameraUsageDescription": "אנחנו צריכים גישה למצלמה כדי לצלם תמונת פרופיל",
        "NSPhotoLibraryUsageDescription": "אנחנו צריכים גישה לגלריה כדי לבחור תמונת פרופיל"
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F23"
      },
      "package": "com.kadur.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "אנחנו צריכים את המיקום שלך כדי להציג משחקים בקרבתך"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "אנחנו צריכים גישה לגלריה כדי לבחור תמונת פרופיל",
          "cameraPermission": "אנחנו צריכים גישה למצלמה כדי לצלם תמונת פרופיל"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#007AFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "owner": "kadur"
  }
}
